{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run lsystems",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/lsystems",
      "args": ["examples/abop-page-27-inspired.lsys"],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        { "name": "DISPLAY", "value": "${env:DISPLAY}" },
        { "name": "WAYLAND_DISPLAY", "value": "${env:WAYLAND_DISPLAY}" },
        { "name": "SDL_VIDEODRIVER", "value": "x11" }
      ],
      "externalConsole": false,
      "preLaunchTask": "cmake: build (release)",
      "miDebuggerPath": "/usr/bin/gdb",
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Disable debuginfod",
          "text": "set debuginfod enabled off",
          "ignoreFailures": true
        },
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "Debug lsystems",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build-debug/lsystems",
      "args": ["examples/abop-page-27-inspired.lsys"],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        { "name": "DISPLAY", "value": "${env:DISPLAY}" },
        { "name": "WAYLAND_DISPLAY", "value": "${env:WAYLAND_DISPLAY}" },
        { "name": "SDL_VIDEODRIVER", "value": "x11" }
      ],
      "externalConsole": false,
      "preLaunchTask": "cmake: build (dev)",
      "miDebuggerPath": "/usr/bin/gdb",
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Disable debuginfod",
          "text": "set debuginfod enabled off",
          "ignoreFailures": true
        },
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
